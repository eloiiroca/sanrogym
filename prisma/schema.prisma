// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Participant {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  
  // Implicit many-to-many relation
  sessions  Session[] 
}

model Session {
  id            String        @id @default(uuid())
  sessionNumber Int           @unique
  date          DateTime
  createdAt     DateTime      @default(now())
  
  // Implicit many-to-many relation
  participants  Participant[] 
}